{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**"]
  },
  "disabled_providers": ["openai", "anthropic"], 
  "permission": {
    "lsp": "allow",
    "skill": "allow",
    "webfetch": "allow",
    "question": "allow",
    "bash": {
      "*": "ask",
      "git *": "ask",
      "npm *": "ask",
      "rm *": "deny",
      "grep *": "allow",
      "ls *": "allow"
    },
    "edit": {
      "*": "deny",
      "rules/**": "allow"
    }
  }
}